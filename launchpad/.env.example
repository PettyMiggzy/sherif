# Copy to `.env` (gitignored) and fill in. NEVER commit real keys.

# Robinhood Chain RPC used to FORK mainnet for the fork tests (real Uniswap v3 + WETH).
# Get one from Alchemy/your provider. When set, `npx hardhat test test/fork/*.js` runs against a fork.
FORK_RPC=

# For deploying to Robinhood Chain (chainId 4663)
ROBINHOOD_RPC=
PRIVATE_KEY=
