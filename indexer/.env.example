# ── Robin Labs Pad indexer config ──────────────────────────────────────────
# Copy to .env and fill in. Nothing here is secret unless you use a private RPC.

# RPC endpoint. The public Blockscout eth-rpc works out of the box; swap in a
# private archive RPC (Alchemy/your own node) for faster, higher-limit backfills.
RPC_URL=https://robinhoodchain.blockscout.com/api/eth-rpc

# Deployed Robin Labs contracts (LIVE on Robinhood Chain).
FACTORY=0xc208e393990B6f2BC8D0d330E0be38C6eCA1e25B
ROUTER=0x1988dEFfE3799Fb56F949ffb20C65D20c1547570

# Block to start indexing from. Set this to the factory's deploy block so the
# first backfill doesn't crawl the whole chain. Find it on the explorer:
#   robinhoodchain.blockscout.com/address/<FACTORY> → first tx block.
# 0 = scan from genesis (slower first run, still correct).
START_BLOCK=0

# Tuning.
PORT=8787              # API port
POLL_MS=6000           # how often to poll for new blocks
CHUNK=1500             # blocks per getLogs call (lower it if the RPC rejects the range)
CONFIRMATIONS=3        # treat head-N as final; re-scan the tip each poll for reorgs
DB_PATH=./data/robinlabs.db

# CORS origin allow-list for the API (comma-separated). * = allow any (fine for a
# read-only public API). Lock it to your domain in production if you prefer.
# NOTE: with the docker-compose + Caddy setup the site and API share one origin,
# so CORS never comes into play — leave it as * or set it to your domain.
CORS_ORIGIN=*

# ── docker-compose only ─────────────────────────────────────────────────────
# Your domain. Caddy gets an automatic HTTPS cert for it and serves BOTH the
# static pad and the API here. Leave blank / ":80" for local plain-HTTP testing.
# Then set API_BASE in pad/assets/config.js to "https://<this domain>".
SITE_DOMAIN=

# For a launch that could see 10k people at once, DON'T use the public RPC —
# point RPC_URL above at your Alchemy or QuickNode Robinhood Chain endpoint.
# The indexer is the only thing that talks to the RPC; users' wallets use their
# own. A private RPC also lets you raise CHUNK for much faster backfills.
