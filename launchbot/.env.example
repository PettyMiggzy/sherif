# ── Robin Labs Launch Bot — config. Copy to `.env` and fill in. NEVER commit .env ──

# Telegram bot token from @BotFather. SECRET.
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token

# RPC that can BROADCAST txs (must accept eth_sendRawTransaction). This is the
# paid/premium Robinhood Chain RPC — NOT the read-only indexer /rpc proxy. A key
# in the URL is a SECRET; keep it here, never commit.
RPC_URL=https://your-premium-robinhood-rpc

# 32+ byte secret that encrypts every custodial private key at rest. SECRET.
# If it leaks, every wallet is exposed. If it's lost, every wallet is
# unrecoverable. Generate once:  openssl rand -hex 32
MASTER_SECRET=

# Indexer + site (public). Used for pfp upload and chart links.
API_BASE=https://api.robinlab.io
SITE_BASE=https://robinlab.io

# Optional: your Telegram user id (for admin/logging). Not required.
ADMIN_ID=

# Slippage tolerance for /buy and /sell (percent).
SLIPPAGE_PCT=12

# Optional on-chain bot fee per launch (in ETH), sent to FEE_WALLET. 0 = off.
# This is charged ON-CHAIN in ETH — never via Telegram Stars (ToS-compliant).
LAUNCH_FEE_ETH=0
FEE_WALLET=

# Where /paysupport points users.
SUPPORT_URL=t.me/robinlabs

# Where the encrypted wallet store lives (mount a persistent volume here in prod).
DATA_DIR=./data
