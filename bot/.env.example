# ---- $SHERIFF Buy Bot config (ape.store / Robinhood Chain) ----
# Copy to `.env` and fill in real values. NEVER commit the real .env.

# Telegram (from @BotFather). Keep secret.
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token
TELEGRAM_CHAT_ID=-1003503389902      # group/channel to post buys in
ADMIN_ID=6820752140                  # your Telegram user id (/testbuy, startup ping)

# Token on ape.store
TOKEN_ADDRESS=0x01d8d7995d0e656315715ef0ed3b81d92171b3cc
APE_CHAIN=robinhood
APE_API=https://ape.store/api
EXPLORER=https://robinhoodchain.blockscout.com
NATIVE_SYMBOL=ETH
CHART_URL=                            # defaults to https://ape.store/robinhood/<token>

# Links shown in command buttons / /links
SOCIAL_X=https://x.com/hoodedsheriff
SOCIAL_TG=https://t.me/hoodedsheriff
WEBSITE=                              # your site url (optional)

# Alert tuning
MIN_BUY_USD=0                        # ignore buys under this USD (0 = all)
BUY_EMOJI=🟢
EMOJI_STEP_USD=20                   # one emoji per this many USD
POLL_MS=12000

# ---- Premium RPC (optional but recommended) ----
# Set RPC_URL to your premium Robinhood Chain RPC for INSTANT on-chain buy
# detection (watches the curve/pair directly). Leave blank to poll ape.store.
# An RPC url with a key in it is a SECRET — it lives here in .env, never committed.
RPC_WSS=                             # premium WebSocket (wss://) -> realtime buys (best)
RPC_URL=
RPC_POLL_MS=4000                     # how often to check for new blocks (ms)
PAIR_ADDRESS=0x37F84F3A789FD1C5046F73f5D082c94F4D86b0fE   # auto-detected if blank

# Buy-alert media: by default the bot attaches media/buy.mp4 (the animated
# Sheriff), uploaded once then reused via Telegram file_id. Override with a local
# path or a public URL, or set MEDIA_PATH= (empty) for text-only alerts.
MEDIA_PATH=                          # optional local file (default: media/buy.mp4)
MEDIA_URL=                           # optional public gif/mp4/png url (takes priority)

# ---- PFP generator (/pfp) ----
# Venice API key powers the free Sheriff PFP generator (one per member).
# It's a SECRET — stays in .env, never committed. Leave blank to disable /pfp.
VENICE_API_KEY=
VENICE_IMAGE_MODEL=hunyuan-image-v3

ENABLE_COMMANDS=true                 # /ping /status /curve (all), /testbuy (admin)
