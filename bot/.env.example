# ---- $SHERIFF Buy Bot config ----
# Copy this file to `.env` and fill in real values. NEVER commit the real .env.

# Telegram (from @BotFather). Keep secret.
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token
TELEGRAM_CHAT_ID=-1003503389902      # the group/channel to post buys in
ADMIN_ID=6820752140                  # your Telegram user id (for /testbuy, startup ping)

# Chain / token
RPC_URL=https://rpc.mainnet.chain.robinhood.com
CHAIN_ID=4663
EXPLORER=https://robinhoodchain.blockscout.com
TOKEN_ADDRESS=0xc7249e4ff274f0b246652481671a5ce55acd33b9

# Liquidity pair (LP) address. Leave blank to auto-detect from recent transfers,
# but setting it explicitly is more reliable. Buys = tokens leaving this pair.
PAIR_ADDRESS=

# Optional price/market-cap. If the pair's base token is a stablecoin, USD is
# automatic. If it's a wrapped-native token (e.g. WETH), set its USD price here.
NATIVE_USD=

# Alert tuning
TICKER=SHERIFF
MIN_BUY_USD=0                 # ignore buys under this USD value (0 = all)
BUY_EMOJI=🟢
EMOJI_STEP_USD=25            # one emoji per this many USD
POLL_MS=15000

# Optional links / media shown in each alert
CHART_URL=
BUY_URL=
MEDIA_URL=                   # optional gif/mp4/png url shown with each buy

ENABLE_COMMANDS=true         # /ping /status (all), /testbuy (admin only)
